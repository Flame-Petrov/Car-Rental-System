<Window x:Class="CarRentalSystem_WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Car Rental System" Height="700" Width="1060"
        MinHeight="500" MinWidth="700"
        Background="#F1F5F9"
        FontFamily="Segoe UI">

    <Window.Resources>

        <!-- Sidebar nav button -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Margin="10,2,10,2">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1F2937"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#374151"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Main action button (primary blue) -->
        <Style x:Key="ActionPrimary" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Main action button (outline) -->
        <Style x:Key="ActionOutline" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F9FAFB"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#9CA3AF"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════ SIDEBAR ═══════════════ -->
        <Border Grid.Column="0" Background="#111827">
            <DockPanel>

                <!-- Logo -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="#1F2937" BorderThickness="0,0,0,1"
                        Padding="20,22,20,20">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#2563EB" CornerRadius="8"
                                Width="36" Height="36" Margin="0,0,12,0">
                            <TextBlock Text="&#x1F697;" FontSize="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="CarRental" Foreground="White"
                                       FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="Management" Foreground="#4B5563" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Nav section label -->
                <TextBlock DockPanel.Dock="Top"
                           Text="MENU"
                           Foreground="#374151" FontSize="10" FontWeight="Bold"
                           Margin="22,18,0,6"/>

                <!-- Nav items -->
                <StackPanel DockPanel.Dock="Top">

                    <!-- Cars -->
                    <Button Command="{Binding CarsButtonCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavBtn}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCarsView}" Value="True">
                                        <Setter Property="Background" Value="#1E3A8A"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F697;" FontSize="15" VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <TextBlock Text="Cars" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Renters -->
                    <Button Command="{Binding RentersButtonCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavBtn}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRentersView}" Value="True">
                                        <Setter Property="Background" Value="#1E3A8A"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F464;" FontSize="15" VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <TextBlock Text="Renters" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Documents -->
                    <Button Command="{Binding DocumentsButtonCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavBtn}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDocumentsView}" Value="True">
                                        <Setter Property="Background" Value="#1E3A8A"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4C4;" FontSize="15" VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <TextBlock Text="Documents" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- Bottom version label -->
                <TextBlock DockPanel.Dock="Bottom"
                           Text="v1.0"
                           Foreground="#374151" FontSize="11"
                           HorizontalAlignment="Center" Margin="0,0,0,16"/>

            </DockPanel>
        </Border>

        <!-- ═══════════════ MAIN CONTENT ═══════════════ -->
        <Grid Grid.Column="1" Margin="28,24,28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Section title -->
            <TextBlock Grid.Row="0"
                       Text="{Binding CurrentSectionTitle}"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#111827"/>

            <!-- Search + Filter row -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>

                <!-- Search box -->
                <Border Grid.Column="0"
                        Background="White"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Height="40">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#x1F50D;" FontSize="13"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#9CA3AF"/>
                        <Grid Grid.Column="1">
                            <TextBox BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="13" FontFamily="Segoe UI"
                                     Foreground="#111827"
                                     VerticalContentAlignment="Center"
                                     Padding="2,0,8,0"
                                     FocusVisualStyle="{x:Null}"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Search..." IsHitTestVisible="False"
                                       VerticalAlignment="Center" Foreground="#9CA3AF"
                                       FontSize="13" FontFamily="Segoe UI" Margin="4,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchText}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Filter ComboBox -->
                <ComboBox Grid.Column="2"
                          Style="{StaticResource FilterCombo}"
                          ItemsSource="{Binding FilterOptions}"
                          SelectedItem="{Binding SelectedFilter}"/>
            </Grid>

            <!-- DataGrid card -->
            <Border Grid.Row="4"
                    Background="White"
                    CornerRadius="12"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    ClipToBounds="True">
                <DataGrid x:Name="ItemsDataGrid"
                          ItemsSource="{Binding DisplayedItems}"
                          SelectedItem="{Binding SelectedItem}"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F3F4F6"
                          HeadersVisibility="Column"
                          BorderThickness="0"
                          Background="White"
                          AlternatingRowBackground="#FAFAFA"
                          RowBackground="White"
                          FontSize="13"
                          FontFamily="Segoe UI"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="True"
                          CanUserResizeRows="False"
                          CanUserResizeColumns="True"
                          AutoGeneratingColumn="ItemsDataGrid_AutoGeneratingColumn">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="#6B7280"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="FontFamily" Value="Segoe UI"/>
                            <Setter Property="Padding" Value="14,10"/>
                            <Setter Property="BorderBrush" Value="#F3F4F6"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="MinHeight" Value="44"/>
                            <Setter Property="BorderBrush" Value="#F3F4F6"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EFF6FF"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#BFDBFE"/>
                                    <Setter Property="BorderBrush" Value="#3B82F6"/>
                                    <Setter Property="BorderThickness" Value="3,0,0,1"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Padding" Value="14,0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#1D4ED8"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>

                </DataGrid>
            </Border>

            <!-- Action buttons -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Edit"
                        Style="{StaticResource ActionOutline}"
                        Width="100"
                        Margin="0,0,10,0"
                        Command="{Binding EditCommand}"/>
                <Button Content="+ Add"
                        Style="{StaticResource ActionPrimary}"
                        Width="120"
                        Command="{Binding AddCommand}"/>
            </StackPanel>

        </Grid>
    </Grid>
</Window>
