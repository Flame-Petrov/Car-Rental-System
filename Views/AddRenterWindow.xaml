<Window x:Class="CarRentalSystem_WPF.Views.AddRenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Width="480"
        SizeToContent="Height"
        MinHeight="200" MinWidth="380"
        WindowStartupLocation="CenterOwner"
        Background="White"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#F8FAFC"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,0,1"
                Padding="24,20">
            <StackPanel>
                <TextBlock Text="{Binding WindowTitle}" FontSize="18" FontWeight="Bold" Foreground="#111827"/>
                <TextBlock Text="Renter" FontSize="12" Foreground="#9CA3AF" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Form fields -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,4">

                <TextBlock Text="FULL NAME" Style="{StaticResource FieldLabel}"/>
                <TextBox Style="{StaticResource FormInput}" Text="{Binding FullName}" Margin="0,0,0,16"/>

                <TextBlock Text="DRIVER LICENSE NUMBER" Style="{StaticResource FieldLabel}"/>
                <TextBox Style="{StaticResource FormInput}" Text="{Binding DriverLicense}" Margin="0,0,0,16"
                         AllowDrop="False"
                         PreviewTextInput="IntegerOnly_PreviewTextInput"
                         DataObject.Pasting="IntegerOnly_Pasting"/>

                <TextBlock Text="PHONE NUMBER" Style="{StaticResource FieldLabel}"/>
                <TextBox Style="{StaticResource FormInput}" Text="{Binding PhoneNumber}" Margin="0,0,0,16"
                         MaxLength="15" AllowDrop="False"
                         PreviewTextInput="IntegerOnly_PreviewTextInput"
                         DataObject.Pasting="IntegerOnly_Pasting"/>

                <TextBlock Text="EMAIL" Style="{StaticResource FieldLabel}"/>
                <TextBox Style="{StaticResource FormInput}" Text="{Binding Email}" Margin="0,0,0,4"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2"
                BorderBrush="#E5E7EB"
                BorderThickness="0,1,0,0"
                Padding="24,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource GhostBtn}"
                        Width="90" Margin="0,0,8,0"
                        Command="{Binding CancelCommand}"/>
                <Button Content="Remove"
                        Style="{StaticResource DangerBtn}"
                        Width="90" Margin="0,0,8,0"
                        Command="{Binding RemoveCommand}"
                        Visibility="{Binding ShowRemoveButton}"/>
                <Button Content="{Binding ButtonText}"
                        Style="{StaticResource PrimaryBtn}"
                        Width="90"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
